{
  "name": "pokemon-tcg",
  "version": "1.0.0",
  "description": "Multilingual Pokémon TCG catalog — search any card in EN/JA/KO/ZH and see every regional print side-by-side.",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "tsx scripts/fetch-and-build-data.ts && astro build && pagefind --site dist",
    "build:fixtures": "FIXTURES=1 tsx scripts/fetch-and-build-data.ts && astro build && pagefind --site dist",
    "build:fixtures-empty-prices": "echo '{\"generatedAt\":\"2026-01-01T00:00:00.000Z\",\"records\":{}}' > data/prices-fresh.json && npm run build:fixtures",
    "fetch-prices-fresh": "tsx scripts/fetch-prices-fresh.ts",
    "fetch-exchange-rates": "tsx scripts/fetch-exchange-rates.ts",
    "push-history-to-d1": "tsx scripts/push-history-to-d1.ts",
    "bootstrap-d1-history": "tsx scripts/bootstrap-d1-history.ts",
    "preview": "astro preview",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@astrojs/preact": "^5.1.1",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "astro": "^6.1.8",
    "pagefind": "^1.5.2",
    "preact": "^10.29.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@tcgdex/sdk": "^2.8.0",
    "chart.js": "^4.5.1",
    "js-yaml": "^4.1.1",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  }
}
